%{
#include <stdio.h>
%}

%%
int|void|if|else|while|return
{
    printf("\n%s is a KEYWORD", yytext);
}

[a-zA-Z_][a-zA-Z0-9_]*
{
    printf("\n%s is an IDENTIFIER", yytext);
}

[0-9]+
{
    printf("\n%s is a CONSTANT", yytext);
}

"+"|"-"|"*"|"/"|"="
{
    printf("\n%s is an OPERATOR", yytext);
}

"//".*
{
    printf("\n%s is a COMMENT", yytext);
}

[ \t\n]
{
    /* Ignore spaces, tabs, and newlines */
}

.
{
    printf("\n%s is a SPECIAL CHARACTER", yytext);
}
%%

int yywrap()
{
    return 1;
}

int main()
{
    printf("Enter code to scan:\n");
    yylex();
    return 0;
}
