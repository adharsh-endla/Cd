%{
#include <stdio.h>

int word_count = 0;
int line_count = 0;
%}

%%

[a-zA-Z0-9]+    { word_count++; }
\n              { line_count++; }

%%

int main()
{
    printf("Enter a sentence:\n");

    yylex();

    printf("No. of words : %d\n", word_count);
    printf("No. of lines : %d\n", line_count);

    return 0;
}

int yywrap()
{
    return 1;
}
